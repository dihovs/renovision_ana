# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Get an API key at https://platform.claude.com/settings/keys — powers the
# Vision AI chat widget's conversational replies and price estimates.
# Without this set, the chat widget will show a friendly error instead of chatting.
ANTHROPIC_API_KEY=

# Get a free API key at https://resend.com — used to email new leads (contact form + chat estimate tool)
RESEND_API_KEY=

# Optional: verified sending address once your domain is added in Resend.
# Until then, leave unset and it falls back to Resend's onboarding@resend.dev test sender.
# LEADS_FROM_EMAIL="Renovision AnA Leads <leads@renovisionana.ca>"
